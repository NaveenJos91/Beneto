{% extends 'base.html.twig' %}
{% block title %}{{ nom_projet }} — Accueil{% endblock %}
{% block body %}
    <div style="text-align:center; padding: 30px 0;">
        <h1 style="font-size: 2.6rem; margin-bottom: 12px;">{{ nom_projet }}</h1>
        <p style="font-size: 1.2rem; color:#556;">{{ slogan }}</p>
    </div>
    <div class="card">
        <h2 style="margin-bottom:12px;">Bienvenue</h2>
        <p style="line-height:1.7;">
            Bénéto met en relation des <strong>bénévoles</strong> et des <strong>apprenants</strong>
            pour du tutorat local et gratuit. Les bénévoles publient des annonces selon leurs
            compétences, leurs disponibilités et leur ville ; les apprenants les recherchent par
            thématique et par ville, puis les contactent.
        </p>
        <div style="margin-top:16px;">
            <a href="{{ path('annonce_index') }}" class="btn">Trouver un bénévole</a>
            {% if not app.user %}
                <a href="{{ path('app_register') }}" class="btn">Créer un compte</a>
            {% endif %}
        </div>
    </div>
{% endblock %}
