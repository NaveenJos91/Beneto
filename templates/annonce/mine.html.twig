{% extends 'base.html.twig' %}
{% block title %}Mes annonces — Bénéto{% endblock %}
{% block body %}
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
        <h1>Mes annonces</h1>
        <a class="btn" href="{{ path('annonce_new') }}" style="margin-top:0;">+ Publier une annonce</a>
    </div>

    {% if annonces is empty %}
        <div class="card"><p>Vous n'avez pas encore publié d'annonce.</p></div>
    {% else %}
        {% for annonce in annonces %}
            <div class="card" style="margin-bottom:14px;">
                <h2 style="margin-bottom:4px;">{{ annonce.titre }}</h2>
                <p style="color:#667; font-size:.9rem; margin-bottom:8px;">
                    {{ annonce.theme.nom }} · {{ annonce.ville.nom }} ·
                    {% if annonce.statut == 'validee' %}
                        <span style="color:#256029;">✔ Publiée</span>
                    {% elseif annonce.statut == 'refusee' %}
                        <span style="color:#8A1F1F;">✖ Refusée</span>
                    {% else %}
                        <span style="color:#8a6d1f;">⏳ En attente de validation</span>
                    {% endif %}
                </p>
                <a class="btn" href="{{ path('annonce_edit', {id: annonce.id}) }}" style="margin-top:0;">Modifier</a>
                <form method="post" action="{{ path('annonce_delete', {id: annonce.id}) }}" style="display:inline;"
                      onsubmit="return confirm('Supprimer cette annonce ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_annonce_' ~ annonce.id) }}">
                    <button class="btn btn-danger" type="submit" style="margin-top:0;">Supprimer</button>
                </form>
            </div>
        {% endfor %}
    {% endif %}
{% endblock %}
