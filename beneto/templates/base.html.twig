<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Bénéto{% endblock %}</title>
    <style>
        :root {
            --cream:      #FBF4EC;
            --card:       #FFFFFF;
            --terracotta: #C4633F;
            --terracotta-dark: #A44E2F;
            --coral:      #E8845E;
            --sage:       #6E8B5B;
            --text:       #3B2A24;
            --muted:      #8A756B;
            --border:     #EADFD4;
            --radius:     20px;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: ui-rounded, "Segoe UI", system-ui, -apple-system, "Helvetica Neue", sans-serif;
            color: var(--text);
            line-height: 1.65;
            /* Fond crème avec une texture papier très douce (grain subtil) */
            background-color: var(--cream);
            background-image:
                radial-gradient(rgba(196,99,63,.035) 1px, transparent 1px),
                radial-gradient(rgba(110,139,91,.03) 1px, transparent 1px);
            background-size: 22px 22px, 34px 34px;
            background-position: 0 0, 11px 11px;
        }
        /* --- En-tête --- */
        header {
            background: var(--terracotta);
            color: var(--cream);
            padding: 14px 26px;
            display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;
            gap: 10px;
            box-shadow: 0 3px 14px rgba(164, 78, 47, .2);
        }
        .brand { display: flex; align-items: center; gap: 11px; text-decoration: none; color: var(--cream); }
        .brand .name { font-size: 1.55rem; font-weight: 800; letter-spacing: .3px; }
        /* petit décalage manuscrit du badge */
        .brand svg { transform: rotate(-4deg); }
        header nav { display: flex; flex-wrap: wrap; align-items: center; gap: 4px; }
        header nav a {
            color: var(--cream); text-decoration: none; font-size: .95rem;
            padding: 8px 14px; border-radius: 999px; transition: background .15s;
        }
        header nav a:hover { background: rgba(255,255,255,.16); }

        main { max-width: 920px; margin: 0 auto; padding: 36px 24px; }

        h1, h2, h3 { font-weight: 800; }
        /* --- Soulignement "fait main" sous les titres de section --- */
        .titre-main { position: relative; display: inline-block; }
        .titre-main::after {
            content: ""; position: absolute; left: -2px; right: -6px; bottom: -6px; height: 8px;
            /* trait irrégulier, comme tracé au feutre */
            background: var(--coral);
            border-radius: 50% 40% 45% 55% / 60% 55% 45% 50%;
            opacity: .35; transform: rotate(-1.2deg);
        }

        /* --- Cartes : arrondies, ombre douce asymétrique, très léger décalage --- */
        .card {
            background: var(--card);
            border-radius: 22px 20px 24px 18px; /* coins volontairement pas identiques */
            padding: 28px;
            box-shadow: 6px 8px 24px rgba(59, 42, 36, .08);
            border: 1px solid var(--border);
        }
        .card + .card { margin-top: 16px; }
        /* chaque carte légèrement inclinée différemment (fait main) */
        main > .card:nth-of-type(odd)  { transform: rotate(-0.35deg); }
        main > .card:nth-of-type(even) { transform: rotate(0.4deg); }

        /* --- Boutons en pilule --- */
        .btn {
            display: inline-block; margin-top: 14px;
            background: var(--terracotta); color: #fff; border: none;
            padding: 12px 22px; border-radius: 999px; font-size: 1rem; font-weight: 600;
            cursor: pointer; text-decoration: none; transition: background .15s, transform .05s;
            font-family: inherit; box-shadow: 2px 3px 0 rgba(164,78,47,.25);
        }
        .btn:hover { background: var(--terracotta-dark); }
        .btn:active { transform: translateY(1px); box-shadow: 1px 1px 0 rgba(164,78,47,.25); }
        .btn-danger { background: #B3452F; box-shadow: 2px 3px 0 rgba(120,40,25,.25); }
        .btn-danger:hover { background: #93361F; }

        /* --- Champs de formulaire doux --- */
        form label { display: block; margin: 14px 0 5px; font-weight: 600; color: var(--text); }
        form input[type=text], form input[type=email], form input[type=password],
        form select, form textarea {
            width: 100%; padding: 12px 14px; border: 1px solid var(--border);
            border-radius: 12px; font-size: 1rem; font-family: inherit; background: #FFFDFB; color: var(--text);
        }
        form input:focus, form select:focus, form textarea:focus {
            outline: none; border-color: var(--coral); box-shadow: 0 0 0 3px rgba(232,132,94,.18);
        }
        .checkbox-line { display: flex; align-items: center; gap: 8px; margin: 8px 0; }
        .checkbox-line label { font-weight: 400; margin: 0; display: inline; cursor: pointer; }
        .checkbox-line input[type=checkbox] { width: auto; margin: 0; accent-color: var(--terracotta); }

        /* --- Messages --- */
        .flash { padding: 13px 18px; border-radius: 12px; margin-bottom: 16px; font-weight: 600; }
        .flash-success { background: #E7F0E0; color: #3F5A30; }
        .flash-error   { background: #F8E4DC; color: #8A331F; }
        form ul { list-style: none; padding-left: 0; margin: 4px 0; }
        form ul li { background: #F8E4DC; color: #A0402A; font-weight: 600; padding: 8px 12px; border-radius: 10px; margin: 4px 0; }

        a { color: var(--terracotta-dark); }
        footer { text-align: center; padding: 26px; color: var(--muted); font-size: .88rem; }
        footer a { color: var(--muted); }
    </style>
</head>
<body>
    <header>
        <a class="brand" href="{{ path('home') }}">
            <svg width="40" height="40" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="40" height="40" rx="13" fill="#FBEFE7"/>
                <!-- Livre ouvert -->
                <g transform="translate(8,10)" fill="none" stroke="#C4633F" stroke-width="1.9"
                   stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3.2 C 9 1.2, 5 1.2, 1.4 2.6 L 1.4 15 C 5 13.6, 9 13.6, 12 15.6" fill="#F7DFD3"/>
                    <path d="M12 3.2 C 15 1.2, 19 1.2, 22.6 2.6 L 22.6 15 C 19 13.6, 15 13.6, 12 15.6" fill="#FFFFFF"/>
                    <line x1="12" y1="3.2" x2="12" y2="15.6"/>
                </g>
            </svg>
            <span class="name">Bénéto</span>
        </a>
        <nav>
            <a href="{{ path('home') }}">Accueil</a>
            <a href="{{ path('annonce_index') }}">Annonces</a>
            {% if app.user %}
                {% if is_granted('ROLE_BENEVOLE') %}<a href="{{ path('annonce_mine') }}">Mes annonces</a>{% endif %}
                {% if is_granted('ROLE_ADMIN') %}<a href="{{ path('admin_annonces') }}">Modération</a>{% endif %}
                <a href="{{ path('app_profile') }}">Mon profil</a>
                <a href="{{ path('app_logout') }}">Déconnexion</a>
            {% else %}
                <a href="{{ path('app_login') }}">Connexion</a>
                <a href="{{ path('app_register') }}">Inscription</a>
            {% endif %}
        </nav>
    </header>
    <main>
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash-{{ label }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}
        {% block body %}{% endblock %}
    </main>
    <footer>
        Fait avec soin pour rapprocher ceux qui apprennent et ceux qui aident &nbsp;·&nbsp;
        <a href="{{ path('app_privacy') }}">Confidentialité</a>
    </footer>
</body>
</html>
